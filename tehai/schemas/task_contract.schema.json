{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tehai.local/schemas/task_contract.schema.json",
  "title": "TaskContract",
  "description": "The contract every subtask must carry. No contract -> no execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "objective",
    "task_type",
    "expected_output",
    "acceptance_criteria",
    "escalation_conditions",
    "recommended_model"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "parent_task_id": { "type": ["string", "null"] },
    "objective": { "type": "string", "minLength": 4 },
    "task_type": {
      "type": "string",
      "enum": [
        "classification", "extraction", "doc_formatting", "summarization",
        "research", "spec_design", "architecture", "code_implementation",
        "code_review", "test_authoring", "qa", "security_review", "release",
        "incident_response", "content", "integration", "generic"
      ]
    },
    "input_artifacts": { "type": "array", "items": { "type": "string" } },
    "expected_output": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "required_tools": { "type": "array", "items": { "type": "string" } },
    "estimated_context_tokens": { "type": "integer", "minimum": 0 },
    "estimated_steps": { "type": "integer", "minimum": 1 },
    "complexity_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "ambiguity_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "context_size_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "tool_risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "domain_specialization_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "recommended_model": { "type": "string", "enum": ["small", "medium", "large"] },
    "recommended_effort": { "type": "string", "enum": ["low", "medium", "high", "xhigh", "max"] },
    "assigned_agent_template": { "type": ["string", "null"] },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "escalation_conditions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "done_definition": { "type": "array", "items": { "type": "string" } },
    "depth": { "type": "integer", "minimum": 0 },
    "status": {
      "type": "string",
      "enum": [
        "pending", "ready", "running", "blocked", "reviewing", "accepted",
        "rejected", "retrying", "escalated", "completed", "failed"
      ]
    }
  }
}
