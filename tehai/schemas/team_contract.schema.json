{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tehai.local/schemas/team_contract.schema.json",
  "title": "TeamContract",
  "description": "The unit of controlled delegation between the Meta Orchestrator and a team.",
  "type": "object",
  "additionalProperties": false,
  "required": ["team_task_id", "assigned_team", "objective", "expected_outputs", "acceptance_criteria"],
  "properties": {
    "team_task_id": { "type": "string", "minLength": 1 },
    "assigned_team": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 4 },
    "input_artifacts": { "type": "array", "items": { "type": "string" } },
    "expected_outputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "downstream_teams": { "type": "array", "items": { "type": "string" } },
    "escalation_conditions": { "type": "array", "items": { "type": "string" } },
    "autonomy_level": {
      "type": "string",
      "enum": ["manual", "supervised", "autonomous_low_risk", "autonomous_with_budget", "fully_blocked_for_high_risk"]
    },
    "status": {
      "type": "string",
      "enum": ["planned", "assigned", "decomposing", "executing", "waiting_for_dependency",
               "reviewing", "returned_for_revision", "escalated", "integrated", "completed", "failed"]
    },
    "loop_count": { "type": "integer", "minimum": 0 }
  }
}
